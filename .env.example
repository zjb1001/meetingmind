# MeetingMind 配置文件模板
# ═══════════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入你的真实配置
# ⚠️ 警告: .env 文件包含敏感信息，请勿提交到Git！
# ═══════════════════════════════════════════════════════════════

# ┌──────────────────────────────────────────────────────────────┐
# │ API 配置                                                      │
# └──────────────────────────────────────────────────────────────┘

# 智谱 GLM API 配置 (推荐)
ANTHROPIC_API_KEY=your_zhipu_key_here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ANTHROPIC_MODEL=glm-4.7

# 或 OpenAI Whisper API 配置
# ANTHROPIC_API_KEY=your_openai_key_here
# ANTHROPIC_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_MODEL=gpt-4

# API 超时和重试配置
API_TIMEOUT=60
API_MAX_RETRIES=3
API_RETRY_DELAY=1.0

# ┌──────────────────────────────────────────────────────────────┐
# │ 音频配置                                                      │
# └──────────────────────────────────────────────────────────────┘

# 音频采样率 (支持: 8000, 16000, 44100, 48000)
AUDIO_SAMPLE_RATE=16000

# 音频通道数 (1=单声道, 2=立体声)
AUDIO_CHANNELS=1

# 音频块大小
AUDIO_CHUNK=1024

# 音频输入设备索引 (可选，留空使用默认设备)
# AUDIO_INPUT_DEVICE=0

# ┌──────────────────────────────────────────────────────────────┐
# │ 输出配置                                                      │
# └──────────────────────────────────────────────────────────────┘

# 输出目录
OUTPUT_DIR=.

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志文件 (可选，留空则只输出到控制台)
# LOG_FILE=logs/meetingmind.log

# ┌──────────────────────────────────────────────────────────────┐
# │ 评价配置 (通常不需要修改)                                    │
# └──────────────────────────────────────────────────────────────┘

# 评价权重 (总和应为 1.0)
# EVAL_WEIGHT_COMPLETENESS=0.25
# EVAL_WEIGHT_ACCURACY=0.20
# EVAL_WEIGHT_STRUCTURE=0.20
# EVAL_WEIGHT_ACTION_ITEMS=0.25
# EVAL_WEIGHT_READABILITY=0.10
